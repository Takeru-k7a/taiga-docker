# Osolab Auth issuer for local development.
# Keep real client secrets out of git.

OIDC_BASE_URL=https://auth.osolab-auth.jp
OIDC_OP_JWKS_ENDPOINT=https://auth.osolab-auth.jp/jwks
OIDC_OP_AUTHORIZATION_ENDPOINT=https://auth.osolab-auth.jp/authorize
OIDC_OP_TOKEN_ENDPOINT=https://auth.osolab-auth.jp/token
OIDC_OP_USER_ENDPOINT=https://auth.osolab-auth.jp/userinfo

OIDC_RP_CLIENT_ID=30000000000000000000000000000001
OIDC_RP_CLIENT_SECRET=3333333333333333333333333333333333333333333333333333333333333333
OIDC_RP_SCOPES=openid profile email
OIDC_RP_SIGN_ALGO=RS256
OIDC_OSOLAB_SKIP_ID_TOKEN_SIGNATURE=False
