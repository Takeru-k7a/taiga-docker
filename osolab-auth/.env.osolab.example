# Osolab Auth issuer for local development.
# Keep real client secrets out of git.

OIDC_BASE_URL=http://localhost:5040
OIDC_OP_JWKS_ENDPOINT=http://localhost:5040/.well-known/jwks.json
OIDC_OP_AUTHORIZATION_ENDPOINT=http://localhost:5040/connect/authorize
OIDC_OP_TOKEN_ENDPOINT=http://localhost:5040/connect/token
OIDC_OP_USER_ENDPOINT=http://localhost:5040/connect/userinfo

OIDC_RP_CLIENT_ID=taiga-portfolio
OIDC_RP_CLIENT_SECRET=change-me
OIDC_RP_SCOPES=openid profile email
OIDC_RP_SIGN_ALGO=RS256
